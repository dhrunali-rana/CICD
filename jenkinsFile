pipeline {
    agent any
    tools {
        maven 'apache-maven-3.9.14'   // name configured in Global Tool Configuration
        jdk 'jdk-25.0.2.10-hotspot'        // name configured in Global Tool Configuration
    }
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/dhrunali-rana/CICD.git'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean install'
            }
        }
        stage('Test') {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying application...'
                // Add deployment steps here (Tomcat, Docker, etc.)
            }
        }
    }
}